<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ferreteria.ferreteriapro.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <HBox spacing="20.0" alignment="CENTER_RIGHT" style="-fx-background-color: #313244; -fx-padding: 10; -fx-background-radius: 5;">
        <Label fx:id="lblSesionInfo" text="👤 Usuario: [Nombre] | Rol: [Rol]" textFill="#cdd6f4" style="-fx-font-weight: bold;"/>
        <Button text="🚪 Cerrar Sesión" onAction="#onLogoutClick" 
                style="-fx-background-color: #f38ba8; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

    <Label text="Sistema de Inventario y Ventas - Ferretería Pro"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE">
        <tabs>
            <Tab text="🛒 Ventas">
            <VBox spacing="10.0">
                <padding>
                    <Insets top="15.0" bottom="15.0" left="15.0" right="15.0"/>
                </padding>
                
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="PUNTO DE VENTA - Buscar Producto:" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <TextField fx:id="txtBuscador" promptText="🔍 Escribe código o nombre del producto..." style="-fx-font-size: 14px; -fx-padding: 8;"/>
                    </VBox>
                    <Button fx:id="btnSalida" text="💰 REALIZAR VENTA" onAction="#onSalidaClick" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10 25; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    <Button text="🪟 NUEVA VENTA" onAction="#onNuevaVentaFlotanteClick" 
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px; -fx-padding: 10 18; -fx-background-radius: 5; -fx-cursor: hand;"/>
                </HBox>

                    <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colCodigo" text="Código" prefWidth="80" />
                            <TableColumn fx:id="colNombre" text="Producto" prefWidth="200" />
                            <TableColumn fx:id="colPrecio" text="Precio Venta" prefWidth="100" />
                            <TableColumn fx:id="colStock" text="Stock" prefWidth="80" />
                            <TableColumn fx:id="colProveedor" text="Proveedor" prefWidth="120" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <Tab fx:id="tabGestion" text="🛠️ Gestión de Productos">
                <VBox spacing="20.0">
                    <padding>
                        <Insets top="20.0" bottom="20.0" left="20.0" right="20.0"/>
                    </padding>
                    
                    <Label text="Registro y Modificación de Artículos" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    
                    <HBox spacing="15.0" alignment="CENTER_LEFT" style="-fx-background-color: #f5f5f5; -fx-padding: 10; -fx-background-radius: 5;">
                        <Label text="Seleccionar producto existente:" style="-fx-font-weight: bold;"/>
                        <org.controlsfx.control.SearchableComboBox fx:id="comboBusquedaGestion" promptText="Escriba el nombre o código..." HBox.hgrow="ALWAYS"/>
                        <Button text="Refrescar Formulario" onAction="#limpiarCampos" style="-fx-background-color: #607D8B; -fx-text-fill: white;"/>
                    </HBox>

                    <Separator />
                    
                    <GridPane hgap="15.0" vgap="15.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="200.0" />
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" prefWidth="200.0" />
                        </columnConstraints>
                        <children>
                            <Label text="Código (HM-XXX):" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtCodigo" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            
                            <Label text="Nombre Producto:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtNombre" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                            
                            <Label text="Costo Compra ($):" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtPrecioCompra" promptText="0.00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            
                            <Label text="\% Ganancia:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtPorcentajeGanancia" text="30" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                            
                            <Label text="\% IVA:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtPorcentajeIva" text="19" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            
                            <Label text="Precio Venta Final:" style="-fx-font-weight: bold; -fx-text-fill: #2196F3;" GridPane.rowIndex="2" GridPane.columnIndex="2"/>
                            <TextField fx:id="txtPrecio" editable="false" style="-fx-background-color: #e3f2fd; -fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="3"/>
                            
                            <Label text="Stock Inicial:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <TextField fx:id="txtStock" text="0" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                            
                            <Label text="Proveedor:" GridPane.rowIndex="3" GridPane.columnIndex="2"/>
                            <org.controlsfx.control.SearchableComboBox fx:id="comboProveedorGestion" promptText="Seleccionar proveedor..." GridPane.rowIndex="3" GridPane.columnIndex="3"/>
                        </children>
                    </GridPane>

                    <Separator />

                    <HBox spacing="15.0" alignment="CENTER_RIGHT">
                        <Button text="➕ Nuevo Producto" onAction="#onNuevoProductoClick" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-padding: 8 20; -fx-font-weight: bold;"/>
                        <Button text="Eliminar Producto" onAction="#onEliminarClick" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-padding: 8 20;"/>
                        <Button text="Guardar Cambios" onAction="#onGuardarClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20;"/>
                    </HBox>
                </VBox>
            </Tab>
            <Tab fx:id="tabHistorialVentas" text="Historial de Ventas" onSelectionChanged="#actualizarHistorial">
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                    </padding>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Registro de Ventas Realizadas" style="-fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="💰 Cerrar Caja Hoy" onAction="#onCerrarCajaClick" 
                                style="-fx-background-color: #FF9800; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="📈 Reporte Mensual" onAction="#onReporteMensualClick" 
                                style="-fx-background-color: #673AB7; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="📊 Ganancias Totales" onAction="#onReporteGananciasClick" 
                                style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                    <TableView fx:id="tablaVentas" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colVentaId" text="ID" prefWidth="50" />
                            <TableColumn fx:id="colVentaFecha" text="Fecha / Hora" prefWidth="150" />
                            <TableColumn fx:id="colVentaProducto" text="Producto" prefWidth="150" />
                            <TableColumn fx:id="colVentaCant" text="Cant." prefWidth="60" />
                            <TableColumn fx:id="colVentaTotal" text="Total" prefWidth="100" />
                            <TableColumn fx:id="colVentaMetodo" text="Pago" prefWidth="100" />
                            <TableColumn fx:id="colVentaUsuario" text="Cajero" prefWidth="120" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>
            <Tab fx:id="tabHistorialCompras" text="Historial de Compras" onSelectionChanged="#actualizarHistorialCompras">
                <VBox spacing="10.0">
                    <padding>
                        <Insets top="10.0" bottom="10.0" left="10.0" right="10.0"/>
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <Label text="Registro de Entradas de Mercancía" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="➕ Registrar Nueva Compra" onAction="#onEntradaClick" 
                                style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        <Button text="✏️ Editar Registro" onAction="#onEditarEntradaClick" 
                                style="-fx-background-color: #FF9800; -fx-text-fill: white;"/>
                        <Button text="📦 Realizar Cierre Mensual (Archivar)" onAction="#onCierreMensualClick" 
                                style="-fx-background-color: #607D8B; -fx-text-fill: white; -fx-font-weight: bold;"/>
                    </HBox>
                    <TableView fx:id="tablaEntradas" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colEntradaId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colEntradaFecha" text="Fecha Llegada" prefWidth="120"/>
                            <TableColumn fx:id="colEntradaProducto" text="Producto" prefWidth="200"/>
                            <TableColumn fx:id="colEntradaCant" text="Cantidad" prefWidth="80"/>
                            <TableColumn fx:id="colEntradaCosto" text="Costo Unit." prefWidth="100"/>
                            <TableColumn fx:id="colEntradaProveedor" text="Proveedor" prefWidth="150"/>
                            <TableColumn fx:id="colEntradaUsuario" text="Responsable" prefWidth="120"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>
            <Tab fx:id="tabUsuarios" text="👥 Usuarios" onSelectionChanged="#actualizarListaUsuarios">
                <VBox spacing="15.0">
                    <padding>
                        <Insets top="15.0" bottom="15.0" left="15.0" right="15.0"/>
                    </padding>
                    <Label text="Gestión de Accesos al Sistema" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    
                    <GridPane hgap="10" vgap="10" style="-fx-background-color: #f5f5f5; -fx-padding: 15; -fx-background-radius: 5;">
                        <Label text="Nombre Completo:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <TextField fx:id="txtUsuarioNombre" promptText="Ej: Juan Pérez" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        
                        <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                        <TextField fx:id="txtUsuarioLogin" promptText="Ej: jperez" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                        
                        <Label text="Contraseña:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <PasswordField fx:id="txtUsuarioPass" promptText="Nueva contraseña" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        
                        <Label text="Rol:" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                        <ComboBox fx:id="comboUsuarioRol" promptText="Seleccionar..." GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                        
                        <HBox spacing="10" alignment="CENTER_RIGHT" GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="4">
                            <Button text="Limpiar" onAction="#limpiarCamposUsuario"/>
                            <Button text="Eliminar Usuario" onAction="#onEliminarUsuarioClick" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                            <Button text="💾 Guardar / Actualizar" onAction="#onGuardarUsuarioClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;"/>
                        </HBox>
                    </GridPane>

                    <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colUsuarioId" text="ID" prefWidth="50" />
                            <TableColumn fx:id="colUsuarioFull" text="Nombre Real" prefWidth="250" />
                            <TableColumn fx:id="colUsuarioNick" text="Username" prefWidth="150" />
                            <TableColumn fx:id="colUsuarioRol" text="Rol" prefWidth="150" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>
            <Tab fx:id="tabProveedores" text="🤝 Proveedores" onSelectionChanged="#actualizarListaProveedores">
                <VBox spacing="15.0">
                    <padding>
                        <Insets top="15.0" bottom="15.0" left="15.0" right="15.0"/>
                    </padding>
                    <Label text="Gestión de Proveedores" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                    
                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Label text="Nombre del Proveedor:"/>
                        <TextField fx:id="txtNombreProveedor" promptText="Nombre de la empresa..." HBox.hgrow="ALWAYS"/>
                        <Button text="Guardar" onAction="#onGuardarProveedorClick" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                        <Button text="Eliminar" onAction="#onEliminarProveedorClick" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                        <Button text="Nuevo" onAction="#limpiarCamposProveedor"/>
                    </HBox>

                    <TableView fx:id="tablaProveedores" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colProvId" text="ID" prefWidth="50" />
                            <TableColumn fx:id="colProvNombre" text="Nombre Empresa" prefWidth="400" />
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>