<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ferreteria.ferreteriapro.HelloController"
      style="-fx-background-color: #f0f2f5;">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Gestión de Inventario - Ferretería"
           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a202c;"/>

    <HBox spacing="10">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Nombre del Producto"/>
            <TextField fx:id="txtNombre" promptText="Ej: Martillo de uña"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Precio Venta"/>
            <TextField fx:id="txtPrecio" promptText="0.00" prefWidth="100"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Stock Inicial"/>
            <TextField fx:id="txtStock" promptText="0" prefWidth="80"/>
        </VBox>
    </HBox>

    <Button text="Registrar Producto" onAction="#onGuardarClick"
            style="-fx-background-color: #3182ce; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>

    <Separator/>

    <TableView fx:id="tablaProductos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNombre" text="Producto" prefWidth="200"/>
            <TableColumn fx:id="colPrecio" text="Precio"/>
            <TableColumn fx:id="colStock" text="Stock"/>
        </columns>
    </TableView>
</VBox>